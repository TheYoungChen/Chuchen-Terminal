{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Chuchen Terminal",
  "version": "0.1.0",
  "identifier": "com.chuchen.terminal",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:6173",
    "beforeDevCommand": "node scripts/ensure-vite-dev.mjs",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Chuchen Terminal",
        "width": 1440,
        "height": 920,
        "resizable": true,
        "fullscreen": false,
        "minWidth": 1200,
        "minHeight": 760,
        "center": true,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
