{
  "name": "chuchen-terminal-app",
  "private": true,
  "description": "Windows-first local terminal workbench for multi-workspace and AI CLI workflows.",
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite --configLoader native",
    "build": "vue-tsc --noEmit && vite build --configLoader native",
    "preview": "vite preview --configLoader native",
    "tauri": "tauri",
    "tauri:dev": "node scripts/tauri-dev-runner.mjs",
    "tauri:build": "tauri build",
    "test:desktop": "wdio run wdio.conf.mjs"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@tauri-apps/api": "2.10.1",
    "@tauri-apps/plugin-dialog": "2.6.0",
    "@tauri-apps/plugin-notification": "2.3.3",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "vue": "^3.5.22"
  },
  "devDependencies": {
    "@tauri-apps/cli": "2.10.1",
    "@vitejs/plugin-vue": "^6.0.1",
    "@wdio/cli": "^9.27.2",
    "@wdio/local-runner": "^9.27.2",
    "@wdio/mocha-framework": "^9.27.2",
    "@wdio/spec-reporter": "^9.27.2",
    "puppeteer-core": "^25.1.0",
    "typescript": "~6.0.2",
    "vite": "^8.0.4",
    "vue-tsc": "^3.1.0"
  }
}
